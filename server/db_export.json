  "articles": [
    {
      "id": 1,
      "subcategory_id": 7,
      "title": "杨凌三智科技有限公司简介",
      "title_en": "About Yangling Sanzhi Technology",
      "summary": "杨凌三智科技是一家专注于水土保持智能监测领域的高新技术企业。",
      "summary_en": "Yangling Sanzhi is a high-tech enterprise focused on intelligent monitoring for soil and water conservation.",
      "content": "<p>杨凌三智科技有限公司成立于杨凌农业高新技术产业示范区，依托西北农林科技大学和水土保持研究所的科研优势，致力于水土保持智能监测技术的研发与应用。</p><p>公司拥有多项自主知识产权，产品覆盖径流泥沙监测、风蚀监测、生态气象监测等多个领域。</p>",
      "content_en": null,
      "cover_image": "https://images.unsplash.com/photo-1486406146926-c627a92ad1ab?w=800&q=80",
      "author": "",
      "source": "",
      "is_featured": 1,
      "view_count": 0,
      "status": 1,
      "sort_order": 1,
      "published_at": "2026-06-04T06:15:35.000Z",
      "created_at": "2026-06-04T06:15:35.000Z",
      "updated_at": "2026-06-04T06:15:35.000Z"
    },
    {
      "id": 2,
      "subcategory_id": 7,
      "title": "公司发展历程",
      "title_en": "Company History",
      "summary": "从初创到行业领先，杨凌三智科技的成长之路。",
      "summary_en": "From startup to industry leader, the growth journey of Yangling Sanzhi.",
      "content": "<p>自成立以来，公司始终坚持以科技创新为核心驱动力，逐步建立起完善的产品体系和市场网络。</p>",
      "content_en": null,
      "cover_image": "https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=800&q=80",
      "author": "",
      "source": "",
      "is_featured": 1,
      "view_count": 0,
      "status": 1,
      "sort_order": 2,
      "published_at": "2026-06-04T06:15:35.000Z",
      "created_at": "2026-06-04T06:15:35.000Z",
      "updated_at": "2026-06-04T06:15:35.000Z"
    },
    {
      "id": 5,
      "subcategory_id": 14,
      "title": "径流泥沙自动监测系统介绍",
      "title_en": "Runoff Sediment Automatic Monitoring System",
      "summary": "全自动径流泥沙监测设备，实时采集高精度数据。",
      "summary_en": "Fully automatic runoff sediment monitoring equipment with real-time high-precision data collection.",
      "content": "<p>本系统采用先进的传感器技术和自动化控制，能够全天候监测径流小区的水沙变化过程，为水土保持研究提供可靠的数据支撑。</p>",
      "content_en": null,
      "cover_image": "https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?w=800&q=80",
      "author": "",
      "source": "",
      "is_featured": 1,
      "view_count": 0,
      "status": 1,
      "sort_order": 1,
      "published_at": "2026-06-04T06:15:35.000Z",
      "created_at": "2026-06-04T06:15:35.000Z",
      "updated_at": "2026-06-04T06:15:35.000Z"
    },
    {
      "id": 6,
      "subcategory_id": 24,
      "title": "杨凌三智科技合伙人招募计划",
      "title_en": "Partner Recruitment Program",
      "summary": "诚邀有志之士加入，共创水土保持监测事业新篇章。",
      "summary_en": "We invite ambitious partners to join us in writing a new chapter for soil and water conservation monitoring.",
      "content": "<p>公司推出全新的合伙人制度，面向全国招募区域合作伙伴，共享品牌、产品和技术资源，实现互利共赢。</p>",
